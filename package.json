{
  "name": "praxis",
  "productName": "Praxis",
  "version": "0.0.1",
  "description": "AI design & prototyping tool — chat on the left, live preview of your repo on the right",
  "main": "./out/main/index.js",
  "license": "MIT",
  "bin": {
    "praxis": "bin/praxis.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "trustedDependencies": [
    "electron",
    "esbuild"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-electron.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "link": "bun link",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:preview": "tsc --noEmit -p tsconfig.preview.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:preview",
    "test:feedback-dialog": "electron-vite build && node test/feedback-dialog.mjs",
    "test:smoke": "electron-vite build && node test/smoke.mjs",
    "test:menu": "electron-vite build && node test/menu-recents.mjs",
    "test:preview": "electron-vite build && node test/open-preview.mjs",
    "test:mobileframe": "electron-vite build && node test/mobile-frame.mjs",
    "test:viewport": "electron-vite build && node test/viewport-per-project.mjs",
    "test:chat": "electron-vite build && node test/chat-render.mjs",
    "test:select": "electron-vite build && node test/select-element.mjs",
    "test:props": "electron-vite build && node test/prop-edit.mjs",
    "test:style-edit": "electron-vite build && node test/style-edit.mjs",
    "test:custom-controls": "electron-vite build && node test/custom-controls.mjs",
    "test:props-svelte": "electron-vite build && node test/prop-edit-svelte.mjs",
    "test:codepeek": "electron-vite build && node test/code-peek.mjs",
    "test:codedrawer": "electron-vite build && node test/code-drawer.mjs",
    "test:annotations": "electron-vite build && node test/annotations.mjs",
    "test:tokens": "electron-vite build && node test/tokens.mjs",
    "test:gating": "electron-vite build && node test/ready-gating.mjs",
    "test:text": "electron-vite build && node test/text-edit.mjs",
    "test:text-svelte": "electron-vite build && node test/text-edit-svelte.mjs",
    "test:setup": "electron-vite build && node test/setup-detect.mjs",
    "test:restart": "electron-vite build && node test/setup-restart.mjs",
    "test:sim-detect": "electron-vite build && node test/sim-detect.mjs",
    "test:sim-preflight": "electron-vite build && node test/sim-preflight.mjs",
    "test:sim-frame": "electron-vite build && node test/sim-frame.mjs",
    "test:sim-control": "electron-vite build && node test/sim-control.mjs",
    "test:sim-e2e": "electron-vite build && node test/sim-e2e.mjs",
    "test:prbody": "bun test/pr-body.mjs",
    "test:feedback-body": "bun test/feedback-body.mjs",
    "test:slash-token": "bun test/slash-token.mjs",
    "test:skills": "bun test/skills-discovery.mjs",
    "test:devnet": "bun test/devserver-net.mjs",
    "test:xcode": "bun test/xcode.mjs",
    "test:git": "bun test/git.mjs",
    "test:sidecar-migrate": "bun test/sidecar-migrate.mjs",
    "test:update": "bun test/update.mjs",
    "test:diag-cache": "bun test/diag-cache.mjs",
    "test:diag-rules": "bun test/diag-rules.mjs",
    "test:diagnose-card": "electron-vite build && node test/diagnose-card.mjs",
    "test:agent": "electron-vite build && node test/agent-e2e.mjs",
    "test:controls-agent": "electron-vite build && node test/controls-agent.mjs",
    "test:codex": "electron-vite build && node test/codex-e2e.mjs",
    "test:tokens-scaffold": "electron-vite build && node test/tokens-scaffold.mjs",
    "test": "node test/run.mjs unit electron",
    "verify": "node test/run.mjs all",
    "test:props-self": "electron-vite build && node test/prop-svelte-self.mjs",
    "test:comment": "electron-vite build && node test/comment-mode.mjs",
    "test:spawn": "electron-vite build && node test/spawn-comment.mjs",
    "test:chat-isolation": "electron-vite build && node test/chat-isolation.mjs",
    "test:projkey": "bun test/project-key.mjs",
    "test:devmulti": "electron-vite build && node test/devserver-multi.mjs",
    "test:static-serve": "electron-vite build && node test/static-serve.mjs",
    "test:agentmulti": "electron-vite build && node test/agent-multi.mjs",
    "test:agentcap": "electron-vite build && node test/agent-cap.mjs",
    "test:chatroute": "electron-vite build && node test/chat-route.mjs",
    "test:previewlocation": "electron-vite build && node test/preview-location.mjs",
    "test:questions": "electron-vite build && node test/questions.mjs",
    "test:rail": "electron-vite build && node test/rail.mjs",
    "test:railcollapse": "electron-vite build && node test/rail-collapse.mjs",
    "test:providerseam": "electron-vite build && node test/provider-seam.mjs",
    "test:sessionstore": "bun test/sessions-store.mjs",
    "test:chat-title": "bun test/chat-title.mjs",
    "test:edithistory": "bun test/edit-history.mjs",
    "test:worktrees": "bun test/worktrees.mjs",
    "test:chat-worktrees": "bun test/chat-worktrees.mjs",
    "test:rules": "bun test/rules.mjs",
    "test:tw-classes": "bun test/tw-classes.mjs",
    "test:tw-styles": "bun test/tw-styles.mjs",
    "test:inline-style": "bun test/inline-style.mjs",
    "test:css-values": "bun test/css-values.mjs",
    "test:control-panels": "bun test/control-panels.mjs",
    "test:agenthistory": "electron-vite build && node test/agent-history.mjs",
    "test:historyui": "electron-vite build && node test/history-ui.mjs",
    "test:svelte-instance": "bun test/svelte-instance.mjs",
    "test:restore": "electron-vite build && node test/restore-reload.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "@babel/parser": "^8.0.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@openai/codex-sdk": "^0.142.3",
    "@replit/codemirror-lang-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^18.3.1",
    "react-docgen": "^8.0.3",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "svelte": "^5.56.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "electron-vite": "^2.3.0",
    "playwright": "^1.61.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
