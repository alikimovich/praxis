{
  "name": "dsgn",
  "version": "0.0.1",
  "description": "AI design & prototyping tool — chat on the left, live preview of your repo on the right",
  "main": "./out/main/index.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "trustedDependencies": [
    "electron",
    "esbuild"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:smoke": "electron-vite build && node test/smoke.mjs",
    "test:preview": "electron-vite build && node test/open-preview.mjs",
    "test:chat": "electron-vite build && node test/chat-render.mjs",
    "test": "electron-vite build && node test/smoke.mjs && node test/open-preview.mjs && node test/chat-render.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "playwright": "^1.61.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
